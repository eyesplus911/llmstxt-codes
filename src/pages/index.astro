---
export const prerender = false;

import Base from '../layouts/Base.astro';
---
<Base title="AI Readiness Scanner" description="Check how AI-ready your website is. Scan robots.txt, llms.txt, ai.txt, and sitemap.xml — free, no sign-up.">
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">How AI-ready is your site?</h1>
      <p class="hero-subtitle">
        Scan your robots.txt, llms.txt, ai.txt, and sitemap.xml — see your AI Readiness Score in seconds.
      </p>

      <form id="scan-form" class="scan-form" aria-label="Domain scanner">
        <div class="input-wrapper">
          <input
            type="text"
            id="domain-input"
            name="domain"
            placeholder="example.com"
            autocomplete="off"
            autocapitalize="none"
            spellcheck="false"
            required
            aria-label="Domain to scan"
          />
          <button type="submit" id="scan-btn" class="scan-btn">
            <span class="btn-text">Scan</span>
            <span class="btn-loading" aria-hidden="true" style="display: none;">&#x27F3;</span>
          </button>
        </div>
        <p id="domain-preview" class="domain-preview" aria-live="polite"></p>
        <p id="scan-error" class="scan-error" role="alert" style="display: none;"></p>
      </form>

      <p class="hero-examples">
        Try: <button class="example-btn" data-domain="cloudflare.com">cloudflare.com</button> ·
        <button class="example-btn" data-domain="stripe.com">stripe.com</button> ·
        <button class="example-btn" data-domain="anthropic.com">anthropic.com</button>
      </p>

      <p class="hero-curl">
        <code>curl https://llmstxt.codes/api/v1/score/example.com | jq .score</code>
      </p>
    </div>
  </section>

  <section id="results" class="results-section" style="display: none;" aria-live="polite">
    <div class="container">
      <div class="results-grid">
        <div class="results-gauge">
          <div id="gauge-container"></div>
        </div>
        <div class="results-breakdown">
          <h2 class="results-heading">Breakdown</h2>
          <div class="sub-scores-grid" id="sub-scores"></div>
        </div>
      </div>

      <div id="improvements" class="improvements-section" style="display: none;">
        <h3 class="improvements-heading">Top ways to improve your score</h3>
        <div id="improvements-list" class="improvements-list"></div>
      </div>

      <div class="results-actions" id="results-actions" style="display: none;">
        <a id="report-link" href="#" class="action-btn action-btn-primary">View Full Report</a>
        <button id="rescan-btn" class="action-btn action-btn-secondary">Re-scan</button>
      </div>
    </div>
  </section>

  <canvas id="confetti-canvas" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 9999;"></canvas>

  <script>
    import { scanDomain, normalizeDomain } from '../lib/scanner';
    import { TIER_CONFIG } from '../lib/scoring';
    import type { ScoreResult } from '../lib/scoring';

    const form = document.getElementById('scan-form') as HTMLFormElement;
    const input = document.getElementById('domain-input') as HTMLInputElement;
    const btn = document.getElementById('scan-btn') as HTMLButtonElement;
    const btnText = btn.querySelector('.btn-text') as HTMLSpanElement;
    const btnLoading = btn.querySelector('.btn-loading') as HTMLSpanElement;
    const preview = document.getElementById('domain-preview')!;
    const errorEl = document.getElementById('scan-error')!;
    const resultsSection = document.getElementById('results')!;
    const gaugeContainer = document.getElementById('gauge-container')!;
    const subScoresEl = document.getElementById('sub-scores')!;
    const improvementsSection = document.getElementById('improvements')!;
    const improvementsList = document.getElementById('improvements-list')!;
    const actionsSection = document.getElementById('results-actions')!;
    const reportLink = document.getElementById('report-link') as HTMLAnchorElement;
    const rescanBtn = document.getElementById('rescan-btn')!;

    let currentDomain = '';

    // Example domain buttons
    document.querySelectorAll('.example-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const domain = (btn as HTMLElement).dataset.domain!;
        input.value = domain;
        runScan(domain);
      });
    });

    input.addEventListener('input', () => {
      const val = input.value.trim();
      if (val) {
        preview.textContent = `Will check: ${normalizeDomain(val)}`;
        preview.style.display = '';
      } else {
        preview.textContent = '';
      }
      errorEl.style.display = 'none';
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const domain = normalizeDomain(input.value);
      if (!domain) return;
      await runScan(domain);
    });

    rescanBtn.addEventListener('click', async () => {
      if (currentDomain) await runScan(currentDomain, true);
    });

    async function runScan(domain: string, force = false) {
      currentDomain = domain;
      errorEl.style.display = 'none';
      btn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = '';
      resultsSection.style.display = '';
      showSkeletons();

      try {
        const result = await scanDomain(domain, force);
        renderResults(result.score, domain);
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : 'Scan failed';
        errorEl.textContent = message;
        errorEl.style.display = '';
        resultsSection.style.display = 'none';
      } finally {
        btn.disabled = false;
        btnText.style.display = '';
        btnLoading.style.display = 'none';
      }
    }

    function showSkeletons() {
      gaugeContainer.innerHTML = '<div class="skeleton-gauge"></div>';
      const labels = ['llms.txt (44%)', 'robots.txt (28%)', 'sitemap.xml (17%)', 'ai.txt (11%)'];
      subScoresEl.innerHTML = labels.map(l => `
        <div class="sub-score-card"><div class="card-header"><span class="status-icon">&#x25CC;</span><span class="card-label">${esc(l)}</span></div>
        <div class="card-body"><div class="score-bar-bg skeleton-bar"></div><span class="score-value">&#x2026;</span></div></div>
      `).join('');
    }

    function renderResults(score: ScoreResult, domain: string) {
      const tier = TIER_CONFIG[score.tier];
      const r = 80, circ = Math.PI * r, off = circ - (score.overall / 100) * circ;

      gaugeContainer.innerHTML = `<div class="gauge-wrap"><svg viewBox="0 0 200 120" role="img" aria-label="AI Readiness Score: ${score.overall} out of 100, tier ${tier.label}">
        <path d="M 20 100 A 80 80 0 0 1 180 100" fill="none" stroke="var(--color-border)" stroke-width="12" stroke-linecap="round"/>
        <path d="M 20 100 A 80 80 0 0 1 180 100" fill="none" stroke="${tier.color}" stroke-width="12" stroke-linecap="round" stroke-dasharray="${circ}" stroke-dashoffset="${circ}">
          <animate attributeName="stroke-dashoffset" from="${circ}" to="${off}" dur="1.2s" begin="0.3s" fill="freeze"/></path>
        <text x="100" y="85" text-anchor="middle" class="g-score">${score.overall}</text>
        <text x="100" y="110" text-anchor="middle" class="g-tier" fill="${tier.color}">${tier.label}</text>
      </svg></div>`;

      const subs = [
        { l: 'llms.txt', s: score.subScores.llmsTxt, w: '44%', p: true },
        { l: 'robots.txt', s: score.subScores.robotsTxt, w: '28%', p: true },
        { l: 'sitemap.xml', s: score.subScores.sitemap, w: '17%', p: false },
        { l: 'ai.txt', s: score.subScores.aiTxt, w: '11%', p: false },
      ];

      subScoresEl.innerHTML = subs.map((s, i) => {
        const icon = s.s > 0 ? '&#x2705;' : '&#x274C;';
        const clr = s.s > 0 ? 'var(--color-success)' : 'var(--color-text-muted)';
        const delay = 0.3 + i * 0.1;
        return `<div class="sub-score-card${s.p ? ' primary' : ''}" style="animation: fadeSlideUp 0.4s ease-out ${delay}s both">
          <div class="card-header"><span class="status-icon">${icon}</span><span class="card-label">${esc(s.l)}</span><span class="card-weight">${s.w}</span></div>
          <div class="card-body"><div class="score-bar-bg"><div class="score-bar-fill" style="width:${Math.max(s.s,2)}%;background:${clr};transition-delay:${delay}s" role="progressbar" aria-valuenow="${s.s}" aria-valuemin="0" aria-valuemax="100"></div></div><span class="score-value">${s.s}</span></div></div>`;
      }).join('');

      if (score.improvements.length > 0) {
        improvementsList.innerHTML = score.improvements.map((imp, i) => `
          <a href="${esc(imp.link)}" class="improvement-card">
            <span class="improvement-number">${i + 1}</span>
            <span class="improvement-action">${esc(imp.action)}</span>
            <span class="improvement-points">+${imp.points} pts</span>
          </a>`).join('');
        improvementsSection.style.display = '';
      } else {
        improvementsSection.style.display = 'none';
      }

      reportLink.href = `/report/${encodeURIComponent(domain)}`;
      actionsSection.style.display = '';

      if (score.overall >= 90) launchConfetti();
    }

    function esc(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    function launchConfetti() {
      const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;

      const colors = ['#22c55e', '#3b82f6', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899'];
      const ps: Array<{ x:number;y:number;vx:number;vy:number;sz:number;c:string;r:number;rs:number;life:number }> = [];
      for (let i = 0; i < 150; i++) {
        ps.push({ x: canvas.width/2+(Math.random()-0.5)*200, y: canvas.height/2, vx:(Math.random()-0.5)*15, vy:Math.random()*-15-5, sz:Math.random()*8+4, c:colors[Math.floor(Math.random()*colors.length)], r:Math.random()*Math.PI*2, rs:(Math.random()-0.5)*0.3, life:1 });
      }
      let frame = 0;
      function animate() {
        if (frame > 120) { ctx!.clearRect(0,0,canvas.width,canvas.height); return; }
        frame++;
        ctx!.clearRect(0,0,canvas.width,canvas.height);
        for (const p of ps) {
          p.x+=p.vx; p.y+=p.vy; p.vy+=0.3; p.r+=p.rs; p.life-=0.008;
          if (p.life<=0) continue;
          ctx!.save(); ctx!.translate(p.x,p.y); ctx!.rotate(p.r); ctx!.globalAlpha=p.life;
          ctx!.fillStyle=p.c; ctx!.fillRect(-p.sz/2,-p.sz/2,p.sz,p.sz*0.6); ctx!.restore();
        }
        requestAnimationFrame(animate);
      }
      animate();
    }

    const urlDomain = new URLSearchParams(window.location.search).get('domain');
    if (urlDomain) { input.value = urlDomain; runScan(normalizeDomain(urlDomain)); }
  </script>
</Base>

<style>
  .hero { padding: var(--space-20) 0 var(--space-16); text-align: center; }
  .hero-title { font-size: var(--text-4xl); font-weight: 700; letter-spacing: -0.02em; margin-bottom: var(--space-4); }
  .hero-subtitle { font-size: var(--text-lg); color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--space-10); }
  .scan-form { max-width: 560px; margin: 0 auto; }

  .input-wrapper {
    display: flex; background: var(--color-surface); border: 2px solid var(--color-border);
    border-radius: var(--radius-xl); overflow: hidden; transition: border-color 0.15s; box-shadow: var(--shadow-md);
  }
  .input-wrapper:focus-within { border-color: var(--color-primary); }
  .input-wrapper input {
    flex: 1; height: 56px; padding: 0 var(--space-5); border: none; outline: none;
    font-size: var(--text-lg); font-family: var(--font-sans); background: transparent; color: var(--color-text);
  }
  .input-wrapper input::placeholder { color: var(--color-text-muted); }

  .scan-btn {
    height: 56px; padding: 0 var(--space-8); background: var(--color-primary); color: white;
    border: none; font-size: var(--text-base); font-weight: 600; font-family: var(--font-sans);
    cursor: pointer; transition: background 0.15s; min-width: 100px;
  }
  .scan-btn:hover:not(:disabled) { background: var(--color-primary-hover); }
  .scan-btn:disabled { opacity: 0.7; cursor: not-allowed; }
  .btn-loading { display: inline-block; animation: spin 1s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .domain-preview { margin-top: var(--space-2); font-size: var(--text-sm); color: var(--color-text-muted); min-height: 1.5em; }
  .scan-error { margin-top: var(--space-2); font-size: var(--text-sm); color: var(--color-error); }

  .hero-examples { margin-top: var(--space-4); font-size: var(--text-sm); color: var(--color-text-muted); }
  .example-btn {
    background: none; border: 1px solid var(--color-border); border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs);
    color: var(--color-text-secondary); cursor: pointer; transition: all 0.15s;
  }
  .example-btn:hover { border-color: var(--color-primary); color: var(--color-primary); background: var(--color-primary-light); }

  .hero-curl { margin-top: var(--space-6); font-size: var(--text-xs); color: var(--color-text-muted); }
  .hero-curl code { font-family: var(--font-mono); background: var(--color-surface); padding: var(--space-1) var(--space-3); border-radius: var(--radius-md); border: 1px solid var(--color-border); }

  .results-section { padding: var(--space-8) 0 var(--space-16); }
  .results-grid { display: grid; grid-template-columns: 240px 1fr; gap: var(--space-8); align-items: start; }
  .results-gauge { text-align: center; }
  .results-heading { font-size: var(--text-lg); font-weight: 600; margin-bottom: var(--space-4); }

  :global(.sub-scores-grid) { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); }
  :global(.sub-score-card) { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-4); }
  :global(.card-header) { display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-3); }
  :global(.status-icon) { font-weight: 700; font-size: var(--text-lg); min-width: 20px; text-align: center; }
  :global(.card-label) { font-weight: 600; font-size: var(--text-sm); flex: 1; }
  :global(.card-weight) { font-size: var(--text-xs); color: var(--color-text-muted); background: var(--color-bg); padding: 2px 6px; border-radius: var(--radius-full); }
  :global(.card-body) { display: flex; align-items: center; gap: var(--space-3); }
  :global(.score-bar-bg) { flex: 1; height: 8px; background: var(--color-bg); border-radius: var(--radius-full); overflow: hidden; }
  :global(.score-bar-fill) { height: 100%; border-radius: var(--radius-full); transition: width 0.8s ease-out; }
  :global(.score-value) { font-weight: 600; font-size: var(--text-sm); min-width: 28px; text-align: right; font-variant-numeric: tabular-nums; }
  :global(.skeleton-bar) { animation: shimmer 1.5s infinite; background: linear-gradient(90deg, var(--color-bg) 25%, var(--color-border) 50%, var(--color-bg) 75%); background-size: 200% 100%; }
  :global(.skeleton-gauge) { width: 200px; height: 120px; margin: 0 auto; background: var(--color-bg); border-radius: var(--radius-lg); animation: shimmer 1.5s infinite; background: linear-gradient(90deg, var(--color-bg) 25%, var(--color-border) 50%, var(--color-bg) 75%); background-size: 200% 100%; }
  :global(.gauge-wrap) { width: 200px; height: 120px; margin: 0 auto; }
  :global(.gauge-wrap svg) { width: 100%; height: 100%; overflow: visible; }
  :global(.g-score) { font-family: var(--font-sans); font-size: 36px; font-weight: 700; fill: var(--color-text); }
  :global(.g-tier) { font-family: var(--font-sans); font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }

  @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  @keyframes fadeSlideUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .improvements-section { margin-top: var(--space-8); padding-top: var(--space-8); border-top: 1px solid var(--color-border); }
  .improvements-heading { font-size: var(--text-base); font-weight: 600; margin-bottom: var(--space-4); }
  :global(.improvements-list) { display: flex; flex-direction: column; gap: var(--space-2); }
  :global(.improvement-card) { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-4); background: var(--color-primary-light); border-radius: var(--radius-md); text-decoration: none; color: var(--color-text); transition: background 0.15s; }
  :global(.improvement-card:hover) { background: #dbeafe; text-decoration: none; }
  :global(.improvement-number) { width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; background: var(--color-primary); color: white; border-radius: var(--radius-full); font-size: var(--text-xs); font-weight: 700; flex-shrink: 0; }
  :global(.improvement-action) { flex: 1; font-size: var(--text-sm); font-weight: 500; }
  :global(.improvement-points) { font-size: var(--text-sm); font-weight: 700; color: var(--color-success); }

  .results-actions { display: flex; justify-content: center; gap: var(--space-3); margin-top: var(--space-8); }
  :global(.action-btn) { padding: var(--space-3) var(--space-6); border-radius: var(--radius-md); font-size: var(--text-sm); font-weight: 600; font-family: var(--font-sans); cursor: pointer; text-decoration: none; border: none; transition: background 0.15s; }
  :global(.action-btn-primary) { background: var(--color-primary); color: white; }
  :global(.action-btn-primary:hover) { background: var(--color-primary-hover); text-decoration: none; }
  :global(.action-btn-secondary) { background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); }
  :global(.action-btn-secondary:hover) { background: var(--color-bg); }

  @media (max-width: 1024px) { .results-grid { grid-template-columns: 1fr; } }
  @media (max-width: 640px) {
    .hero { padding: var(--space-12) 0 var(--space-8); }
    .hero-title { font-size: var(--text-2xl); }
    .hero-subtitle { font-size: var(--text-base); }
    .input-wrapper { flex-direction: column; border-radius: var(--radius-lg); }
    .input-wrapper input { height: 48px; }
    .scan-btn { height: 48px; border-radius: 0; }
    :global(.sub-scores-grid) { grid-template-columns: 1fr; }
    .hero-curl { display: none; }
    .results-actions { flex-direction: column; }
    .results-actions :global(.action-btn) { text-align: center; }
  }
</style>
