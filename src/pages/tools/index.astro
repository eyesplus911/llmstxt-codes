---
import Base from '../../layouts/Base.astro';
export const prerender = true;
---
<Base title="Tools — llms.txt.codes" description="Free tools for AI readiness: generators for llms.txt, robots.txt, ai.txt, and a live validation playground.">
  <div class="tools-page">
    <div class="container content">
      <h1>Tools</h1>
      <p class="lead">Free generators and validators to make your site AI-ready.</p>

      <div class="tools-grid">
        <a href="/tools/generator/llms-txt" class="tool-card">
          <div class="tool-icon">📝</div>
          <h2>llms.txt Generator</h2>
          <p>Create a structured llms.txt file in 3 steps. Define your site's sections and key pages for AI models.</p>
          <span class="tool-link">Generate →</span>
        </a>

        <a href="/tools/generator/robots-txt" class="tool-card">
          <div class="tool-icon">🤖</div>
          <h2>robots.txt Generator</h2>
          <p>Configure AI crawler permissions with presets (AI-friendly, selective, block all) or custom per-bot rules.</p>
          <span class="tool-link">Generate →</span>
        </a>

        <a href="/tools/generator/ai-txt" class="tool-card">
          <div class="tool-icon">📋</div>
          <h2>ai.txt Generator</h2>
          <p>Declare your AI usage policies — what's allowed, what's not, and how to contact you about AI use.</p>
          <span class="tool-link">Generate →</span>
        </a>

        <a href="/tools/playground" class="tool-card">
          <div class="tool-icon">🧪</div>
          <h2>Playground</h2>
          <p>Paste any llms.txt file and get instant validation — structure checks, link verification, size analysis.</p>
          <span class="tool-link">Open →</span>
        </a>
      </div>

      <div class="cta-section">
        <h2>Already have your files?</h2>
        <p>Scan your domain to see how they all come together in your AI Readiness Score.</p>
        <a href="/" class="action-btn action-btn-primary">Scan your domain</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .tools-page { padding: var(--space-8) 0 var(--space-16); }
  .content { max-width: var(--content-width); }
  h1 { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-2); }
  .lead { color: var(--color-text-secondary); margin-bottom: var(--space-8); }

  .tools-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); margin-bottom: var(--space-12); }

  .tool-card {
    display: block; padding: var(--space-6); background: var(--color-surface);
    border: 1px solid var(--color-border); border-radius: var(--radius-lg);
    text-decoration: none; color: inherit; transition: all 0.15s;
  }
  .tool-card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-md); transform: translateY(-1px); }
  .tool-icon { font-size: 28px; margin-bottom: var(--space-3); }
  .tool-card h2 { font-size: var(--text-lg); font-weight: 600; margin-bottom: var(--space-2); }
  .tool-card p { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--leading-relaxed); margin-bottom: var(--space-3); }
  .tool-link { font-size: var(--text-sm); color: var(--color-primary); font-weight: 600; }

  .cta-section { text-align: center; padding: var(--space-8); background: var(--color-primary-light); border-radius: var(--radius-lg); }
  .cta-section h2 { font-size: var(--text-xl); font-weight: 600; margin-bottom: var(--space-2); }
  .cta-section p { color: var(--color-text-secondary); margin-bottom: var(--space-4); }

  :global(.action-btn) { padding: var(--space-3) var(--space-6); border-radius: var(--radius-md); font-size: var(--text-sm); font-weight: 600; font-family: var(--font-sans); cursor: pointer; text-decoration: none; border: none; transition: background 0.15s; display: inline-block; }
  :global(.action-btn-primary) { background: var(--color-primary); color: white; }
  :global(.action-btn-primary:hover) { background: var(--color-primary-hover); }

  @media (max-width: 640px) {
    .tools-grid { grid-template-columns: 1fr; }
  }
</style>
