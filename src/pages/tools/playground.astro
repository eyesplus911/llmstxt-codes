---
import Base from '../../layouts/Base.astro';
export const prerender = true;
---
<Base title="Playground — llms.txt" description="Test and validate llms.txt files in real-time. Paste your content and see instant validation results.">
  <div class="playground-page">
    <div class="container">
      <h1>Playground</h1>
      <p class="lead">Paste an llms.txt file to validate it in real-time.</p>

      <div class="mode-toggle">
        <button class="mode-btn active" data-mode="simple" id="mode-simple">Simple</button>
        <button class="mode-btn" data-mode="advanced" id="mode-advanced">Advanced</button>
      </div>

      <div class="playground-grid">
        <!-- Editor -->
        <div class="editor-pane">
          <div class="pane-header">
            <span>Input</span>
            <div class="pane-actions">
              <select id="template-select" aria-label="Load template">
                <option value="">Load template...</option>
                <option value="minimal">Minimal</option>
                <option value="full">Full example</option>
                <option value="docs">Documentation site</option>
              </select>
              <button class="pane-btn" id="clear-btn">Clear</button>
            </div>
          </div>
          <div class="editor-wrap" id="editor-wrap">
            <textarea id="editor" spellcheck="false" placeholder="# My Site Name

> A brief description of your site.

## Docs

- [Getting Started](https://example.com/docs): Quick start guide
- [API Reference](https://example.com/api): Full API docs"></textarea>
            <div class="line-numbers" id="line-numbers" aria-hidden="true"></div>
          </div>
        </div>

        <!-- Results -->
        <div class="results-pane">
          <div class="pane-header">
            <span>Validation</span>
            <span class="status" id="status">Ready</span>
          </div>
          <div class="results-content" id="results">
            <div class="empty-state">
              <p>Type or paste llms.txt content to see validation results.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .playground-page { padding: var(--space-8) 0 var(--space-16); }
  h1 { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-2); }
  .lead { color: var(--color-text-secondary); margin-bottom: var(--space-6); }

  .mode-toggle { display: inline-flex; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 2px; margin-bottom: var(--space-6); }
  .mode-btn { padding: var(--space-2) var(--space-4); border: none; background: none; border-radius: var(--radius-sm); font-size: var(--text-sm); font-weight: 500; cursor: pointer; font-family: var(--font-sans); color: var(--color-text-muted); transition: all 0.15s; }
  .mode-btn.active { background: white; color: var(--color-text); box-shadow: var(--shadow-sm); }

  .playground-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); min-height: 500px; }

  .editor-pane, .results-pane {
    border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden;
    display: flex; flex-direction: column;
  }
  .pane-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: var(--space-2) var(--space-3); background: var(--color-bg);
    border-bottom: 1px solid var(--color-border); font-size: var(--text-sm); font-weight: 600;
  }
  .pane-actions { display: flex; gap: var(--space-2); align-items: center; }
  .pane-btn { padding: 2px 8px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); background: white; font-size: var(--text-xs); cursor: pointer; font-family: var(--font-sans); }
  .pane-btn:hover { background: var(--color-bg); }
  #template-select { padding: 2px 6px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: var(--text-xs); font-family: var(--font-sans); background: white; }

  .editor-wrap { flex: 1; position: relative; display: flex; }
  #editor {
    flex: 1; width: 100%; border: none; resize: none; padding: var(--space-3) var(--space-3) var(--space-3) 48px;
    font-family: var(--font-mono); font-size: var(--text-sm); line-height: 1.6;
    background: var(--color-surface); color: var(--color-text); outline: none;
    tab-size: 2;
  }
  .line-numbers {
    position: absolute; left: 0; top: 0; bottom: 0; width: 40px; padding: var(--space-3) var(--space-2);
    text-align: right; font-family: var(--font-mono); font-size: var(--text-sm); line-height: 1.6;
    color: var(--color-text-muted); background: var(--color-bg); border-right: 1px solid var(--color-border);
    overflow: hidden; user-select: none;
  }

  .status { font-size: var(--text-xs); font-weight: 500; padding: 1px 6px; border-radius: var(--radius-full); }

  .results-content { flex: 1; padding: var(--space-3); overflow-y: auto; font-size: var(--text-sm); }
  .empty-state { display: flex; align-items: center; justify-content: center; height: 100%; color: var(--color-text-muted); text-align: center; }

  .result-item { padding: var(--space-2) var(--space-3); border-radius: var(--radius-sm); margin-bottom: var(--space-2); }
  .result-pass { background: #f0fdf4; border-left: 3px solid var(--color-tier-ai-ready); }
  .result-warn { background: #fffbeb; border-left: 3px solid var(--color-tier-getting-there); }
  .result-fail { background: #fef2f2; border-left: 3px solid #ef4444; }
  .result-info { background: var(--color-bg); border-left: 3px solid var(--color-primary); }
  .result-label { font-weight: 600; font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
  .result-label.pass { color: var(--color-tier-ai-ready); }
  .result-label.warn { color: var(--color-tier-getting-there); }
  .result-label.fail { color: #ef4444; }
  .result-label.info { color: var(--color-primary); }
  .result-detail { color: var(--color-text-secondary); }

  .stats-bar { display: flex; gap: var(--space-4); padding: var(--space-3); background: var(--color-bg); border-radius: var(--radius-md); margin-bottom: var(--space-4); }
  .stat { text-align: center; }
  .stat-value { font-size: var(--text-xl); font-weight: 700; }
  .stat-label { font-size: var(--text-xs); color: var(--color-text-muted); }

  @media (max-width: 768px) {
    .playground-grid { grid-template-columns: 1fr; min-height: auto; }
    .editor-pane { min-height: 300px; }
    .results-pane { min-height: 250px; }
  }
</style>

<script>
  const editor = document.getElementById('editor') as HTMLTextAreaElement;
  const lineNumbers = document.getElementById('line-numbers')!;
  const results = document.getElementById('results')!;
  const status = document.getElementById('status')!;

  const templates: Record<string, string> = {
    minimal: `# My Site

> A brief description of what my site does.`,
    full: `# My Awesome Project

> An open-source tool for building better software.

## Getting Started

- [Quick Start](https://example.com/docs/quickstart): Get up and running in 5 minutes
- [Installation](https://example.com/docs/install): System requirements and setup

## API Reference

- [REST API](https://example.com/docs/api): Full REST API documentation
- [SDK Reference](https://example.com/docs/sdk): Client library reference

## Blog

- [v2.0 Release](https://example.com/blog/v2): What's new in version 2
- [Performance Guide](https://example.com/blog/perf): Tips for optimal performance`,
    docs: `# My Documentation

> Comprehensive documentation for the My Platform API.

## Guides

- [Authentication](https://example.com/docs/auth): OAuth2 and API key setup
- [Rate Limits](https://example.com/docs/limits): Usage limits and quotas
- [Webhooks](https://example.com/docs/webhooks): Event notifications

## Reference

- [Endpoints](https://example.com/docs/endpoints): All API endpoints
- [Error Codes](https://example.com/docs/errors): Error handling guide
- [Changelog](https://example.com/docs/changelog): API version history`,
  };

  // Line numbers
  function updateLineNumbers() {
    const lines = editor.value.split('\n').length;
    lineNumbers.innerHTML = Array.from({ length: lines }, (_, i) => `<div>${i + 1}</div>`).join('');
  }

  // Validation
  function validate(content: string) {
    if (!content.trim()) {
      results.innerHTML = '<div class="empty-state"><p>Type or paste llms.txt content to see validation results.</p></div>';
      status.textContent = 'Ready';
      status.style.background = '';
      status.style.color = '';
      return;
    }

    const checks: Array<{ type: 'pass' | 'warn' | 'fail' | 'info'; message: string }> = [];
    const lines = content.split('\n');

    // Check title
    const titleLine = lines.find(l => l.startsWith('# '));
    if (titleLine) {
      checks.push({ type: 'pass', message: `Title found: "${titleLine.slice(2).trim()}"` });
    } else {
      checks.push({ type: 'fail', message: 'Missing title. First line should be # Your Site Name' });
    }

    // Check description
    const hasDesc = lines.some(l => l.startsWith('> ') || (l.trim() && !l.startsWith('#') && !l.startsWith('-') && !l.startsWith('[')));
    if (hasDesc) {
      checks.push({ type: 'pass', message: 'Description found' });
    } else {
      checks.push({ type: 'warn', message: 'No description. Add a blockquote (> ...) after the title' });
    }

    // Check sections
    const sections = lines.filter(l => l.startsWith('## '));
    if (sections.length > 0) {
      checks.push({ type: 'pass', message: `${sections.length} section(s): ${sections.map(s => s.slice(3).trim()).join(', ')}` });
    } else {
      checks.push({ type: 'warn', message: 'No sections. Use ## Section Name to organize links' });
    }

    // Check links
    const linkPattern = /\[([^\]]+)\]\(([^)]+)\)/g;
    const allLinks: Array<{ title: string; url: string }> = [];
    for (const line of lines) {
      let match;
      while ((match = linkPattern.exec(line)) !== null) {
        allLinks.push({ title: match[1], url: match[2] });
      }
    }
    if (allLinks.length > 0) {
      checks.push({ type: 'pass', message: `${allLinks.length} link(s) found` });
    } else {
      checks.push({ type: 'warn', message: 'No links found. Add links as - [Title](URL): Description' });
    }

    // Check for broken-looking URLs
    const badUrls = allLinks.filter(l => !l.url.startsWith('http://') && !l.url.startsWith('https://') && l.url !== '#');
    if (badUrls.length > 0) {
      checks.push({ type: 'warn', message: `${badUrls.length} link(s) without full URL: ${badUrls.map(l => l.title).join(', ')}` });
    }

    // Size check
    const size = new Blob([content]).size;
    if (size > 50000) {
      checks.push({ type: 'warn', message: `File is ${(size / 1024).toFixed(1)}KB — consider trimming to under 50KB` });
    } else {
      checks.push({ type: 'info', message: `File size: ${(size / 1024).toFixed(1)}KB` });
    }

    // Content type hint
    checks.push({ type: 'info', message: 'Serve with Content-Type: text/plain or text/markdown' });

    // Render
    const passCount = checks.filter(c => c.type === 'pass').length;
    const total = checks.filter(c => c.type !== 'info').length;
    const allPass = checks.every(c => c.type === 'pass' || c.type === 'info');

    status.textContent = allPass ? 'Valid' : `${passCount}/${total} checks`;
    status.style.background = allPass ? '#f0fdf4' : '#fffbeb';
    status.style.color = allPass ? '#166534' : '#92400e';

    results.innerHTML = checks.map(c => `
      <div class="result-item result-${c.type}">
        <div class="result-label ${c.type}">${c.type === 'pass' ? 'Pass' : c.type === 'warn' ? 'Warning' : c.type === 'fail' ? 'Error' : 'Info'}</div>
        <div class="result-detail">${c.message}</div>
      </div>
    `).join('');
  }

  // Events
  let debounce: ReturnType<typeof setTimeout>;
  editor.addEventListener('input', () => {
    updateLineNumbers();
    clearTimeout(debounce);
    debounce = setTimeout(() => validate(editor.value), 150);
  });

  editor.addEventListener('scroll', () => {
    lineNumbers.scrollTop = editor.scrollTop;
  });

  (document.getElementById('template-select') as HTMLSelectElement).addEventListener('change', (e) => {
    const val = (e.target as HTMLSelectElement).value;
    if (val && templates[val]) {
      editor.value = templates[val];
      updateLineNumbers();
      validate(editor.value);
    }
    (e.target as HTMLSelectElement).value = '';
  });

  document.getElementById('clear-btn')?.addEventListener('click', () => {
    editor.value = '';
    updateLineNumbers();
    validate('');
  });

  // Mode toggle (simple hides line numbers)
  document.getElementById('mode-simple')?.addEventListener('click', () => {
    document.getElementById('mode-simple')!.classList.add('active');
    document.getElementById('mode-advanced')!.classList.remove('active');
    lineNumbers.style.display = 'none';
    editor.style.paddingLeft = 'var(--space-3)';
    localStorage.setItem('playground-mode', 'simple');
  });

  document.getElementById('mode-advanced')?.addEventListener('click', () => {
    document.getElementById('mode-advanced')!.classList.add('active');
    document.getElementById('mode-simple')!.classList.remove('active');
    lineNumbers.style.display = '';
    editor.style.paddingLeft = '48px';
    localStorage.setItem('playground-mode', 'advanced');
  });

  // Restore mode
  const savedMode = localStorage.getItem('playground-mode');
  if (savedMode === 'simple') {
    document.getElementById('mode-simple')?.click();
  }

  updateLineNumbers();
</script>
