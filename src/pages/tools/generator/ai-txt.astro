---
import Base from '../../../layouts/Base.astro';
export const prerender = true;
---
<Base title="Generate ai.txt" description="Generate an ai.txt file to declare your website's AI usage policies.">
  <div class="generator-page">
    <div class="container content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> / <a href="/learn/ai-txt">ai.txt</a> / <span>Generator</span>
      </nav>

      <h1>Generate ai.txt <span class="badge experimental">Experimental</span></h1>
      <p class="lead">Declare how AI companies may use your content.</p>

      <div class="wizard" id="wizard">
        <div class="steps-bar" role="tablist">
          <button class="step-indicator active" data-step="1" role="tab" aria-selected="true">
            <span class="step-num">1</span> Policies
          </button>
          <button class="step-indicator" data-step="2" role="tab" aria-selected="false">
            <span class="step-num">2</span> Export
          </button>
        </div>

        <!-- Step 1: Policy config -->
        <div class="step-panel active" id="step-1" role="tabpanel">
          <h2>AI Usage Policies</h2>

          <div class="field">
            <label for="contact-email">Contact Email</label>
            <input type="email" id="contact-email" placeholder="ai-policy@example.com" />
          </div>

          <h3>Allowed uses</h3>
          <div class="checkbox-group" id="allowed-uses">
            <label class="checkbox-item"><input type="checkbox" value="search" checked /> Search & discovery</label>
            <label class="checkbox-item"><input type="checkbox" value="summarization" checked /> Summarization</label>
            <label class="checkbox-item"><input type="checkbox" value="citation" /> Citation & reference</label>
            <label class="checkbox-item"><input type="checkbox" value="training" /> Model training</label>
            <label class="checkbox-item"><input type="checkbox" value="fine-tuning" /> Fine-tuning</label>
            <label class="checkbox-item"><input type="checkbox" value="embedding" /> Embedding generation</label>
          </div>

          <h3>Disallowed uses</h3>
          <div class="checkbox-group" id="disallowed-uses">
            <label class="checkbox-item"><input type="checkbox" value="training" checked /> Model training</label>
            <label class="checkbox-item"><input type="checkbox" value="fine-tuning" checked /> Fine-tuning</label>
            <label class="checkbox-item"><input type="checkbox" value="reproduction" /> Content reproduction</label>
            <label class="checkbox-item"><input type="checkbox" value="commercial" /> Commercial use without license</label>
          </div>

          <h3>Additional policies</h3>
          <div class="field">
            <label for="custom-policies">Custom policy statements (one per line)</label>
            <textarea id="custom-policies" rows="3" placeholder="Require attribution for all generated content&#10;Do not use user-generated content for training"></textarea>
          </div>

          <div class="field">
            <label for="license">License (SPDX identifier, optional)</label>
            <input type="text" id="license" placeholder="CC-BY-4.0" />
          </div>

          <div class="nav-buttons">
            <span></span>
            <button class="action-btn action-btn-primary" id="next-1">Generate →</button>
          </div>
        </div>

        <!-- Step 2: Export -->
        <div class="step-panel" id="step-2" role="tabpanel">
          <h2>Your ai.txt</h2>
          <p class="hint">Save this at <code>/ai.txt</code> on your domain root.</p>

          <div class="output-box">
            <pre><code id="output"></code></pre>
            <button class="copy-btn" id="copy-btn">Copy</button>
          </div>

          <div class="nav-buttons">
            <button class="action-btn action-btn-secondary" id="prev-2">← Back</button>
            <a href="/" class="action-btn action-btn-primary">Scan your site</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .generator-page { padding: var(--space-8) 0 var(--space-16); }
  .content { max-width: 680px; }
  .breadcrumb { font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-secondary); }
  h1 { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-2); display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
  .lead { color: var(--color-text-secondary); margin-bottom: var(--space-8); }
  h2 { font-size: var(--text-xl); font-weight: 600; margin-bottom: var(--space-4); }
  h3 { font-size: var(--text-lg); font-weight: 600; margin-top: var(--space-6); margin-bottom: var(--space-3); }
  .hint { font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-4); }

  .badge { font-size: var(--text-xs); font-weight: 600; padding: 2px 8px; border-radius: var(--radius-full); text-transform: uppercase; letter-spacing: 0.05em; }
  .experimental { background: #fef3c7; color: #92400e; }

  .steps-bar { display: flex; gap: var(--space-1); margin-bottom: var(--space-8); border-bottom: 1px solid var(--color-border); }
  .step-indicator { flex: 1; padding: var(--space-3); text-align: center; background: none; border: none; border-bottom: 2px solid transparent; font-size: var(--text-sm); font-weight: 500; color: var(--color-text-muted); cursor: pointer; font-family: var(--font-sans); }
  .step-indicator.active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
  .step-indicator.done { color: var(--color-text); }
  .step-num { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; background: var(--color-bg); font-size: 12px; font-weight: 600; margin-right: 4px; }
  .step-indicator.active .step-num { background: var(--color-primary); color: white; }
  .step-indicator.done .step-num { background: var(--color-tier-ai-ready); color: white; }

  .step-panel { display: none; }
  .step-panel.active { display: block; }

  .field { margin-bottom: var(--space-4); }
  .field label { display: block; font-size: var(--text-sm); font-weight: 600; margin-bottom: var(--space-1); }
  .field input, .field textarea { width: 100%; padding: var(--space-3); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: var(--text-base); font-family: var(--font-sans); background: var(--color-surface); color: var(--color-text); }
  .field input:focus, .field textarea:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.15); }

  .checkbox-group { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2); }
  .checkbox-item { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); cursor: pointer; padding: var(--space-2); border-radius: var(--radius-sm); }
  .checkbox-item:hover { background: var(--color-bg); }
  .checkbox-item input { width: 16px; height: 16px; accent-color: var(--color-primary); }

  .nav-buttons { display: flex; justify-content: space-between; margin-top: var(--space-8); }

  .output-box { position: relative; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); margin: var(--space-4) 0; }
  .output-box pre { margin: 0; overflow-x: auto; }
  .output-box code { font-family: var(--font-mono); font-size: var(--text-sm); line-height: 1.6; white-space: pre; }
  .copy-btn { position: absolute; top: var(--space-2); right: var(--space-2); padding: var(--space-1) var(--space-3); border: 1px solid var(--color-border); border-radius: var(--radius-sm); background: white; font-size: var(--text-xs); cursor: pointer; font-family: var(--font-sans); }
  .copy-btn:hover { background: var(--color-bg); }

  :global(.action-btn) { padding: var(--space-3) var(--space-6); border-radius: var(--radius-md); font-size: var(--text-sm); font-weight: 600; font-family: var(--font-sans); cursor: pointer; text-decoration: none; border: none; transition: background 0.15s; display: inline-block; }
  :global(.action-btn-primary) { background: var(--color-primary); color: white; }
  :global(.action-btn-primary:hover) { background: var(--color-primary-hover); }
  :global(.action-btn-secondary) { background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); }
  :global(.action-btn-secondary:hover) { background: var(--color-bg); }
</style>

<script>
  let currentStep = 1;

  function goToStep(step: number) {
    currentStep = step;
    document.querySelectorAll('.step-panel').forEach((p, i) => p.classList.toggle('active', i + 1 === step));
    document.querySelectorAll('.step-indicator').forEach((ind, i) => {
      ind.classList.toggle('active', i + 1 === step);
      ind.classList.toggle('done', i + 1 < step);
    });
    if (step === 2) generateOutput();
  }

  document.getElementById('next-1')?.addEventListener('click', () => goToStep(2));
  document.getElementById('prev-2')?.addEventListener('click', () => goToStep(1));
  document.querySelectorAll('.step-indicator').forEach(ind => {
    ind.addEventListener('click', () => goToStep(parseInt((ind as HTMLElement).dataset.step || '1')));
  });

  function generateOutput() {
    const lines: string[] = ['# AI Policy'];
    const contact = (document.getElementById('contact-email') as HTMLInputElement).value;

    if (contact) lines.push(`Contact: ${contact}`);

    const allowed = Array.from(
      document.querySelectorAll<HTMLInputElement>('#allowed-uses input:checked')
    ).map(cb => cb.value);
    if (allowed.length) lines.push(`Preferred-Model-Use: ${allowed.join(', ')}`);

    const disallowed = Array.from(
      document.querySelectorAll<HTMLInputElement>('#disallowed-uses input:checked')
    ).map(cb => cb.value);
    if (disallowed.length) lines.push(`Disallowed-Model-Use: ${disallowed.join(', ')}`);

    const license = (document.getElementById('license') as HTMLInputElement).value;
    if (license) lines.push(`License: ${license}`);

    const custom = (document.getElementById('custom-policies') as HTMLTextAreaElement).value;
    if (custom.trim()) {
      lines.push('');
      custom.trim().split('\n').filter(Boolean).forEach(line => {
        lines.push(`Policy: ${line.trim()}`);
      });
    }

    document.getElementById('output')!.textContent = lines.join('\n');
  }

  document.getElementById('copy-btn')?.addEventListener('click', () => {
    const text = document.getElementById('output')!.textContent || '';
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-btn')!;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  // Pre-fill from ?domain= query param
  const urlDomain = new URLSearchParams(window.location.search).get('domain');
  if (urlDomain) {
    const email = document.getElementById('contact-email') as HTMLInputElement;
    if (email && !email.value) email.placeholder = `ai-policy@${urlDomain}`;
  }
</script>
