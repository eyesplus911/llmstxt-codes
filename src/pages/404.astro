---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="error-page">
    <div class="container content">
      <div class="error-code">404</div>
      <h1>Page not found</h1>
      <p>The page you're looking for doesn't exist or has been moved.</p>
      <div class="error-actions">
        <a href="/" class="action-btn action-btn-primary">Scan a domain</a>
        <a href="/about" class="action-btn action-btn-secondary">About</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .error-page {
    display: flex; align-items: center; justify-content: center;
    min-height: 60vh; text-align: center; padding: var(--space-8) 0;
  }
  .error-code {
    font-size: 96px; font-weight: 800; color: var(--color-border);
    line-height: 1; margin-bottom: var(--space-4);
  }
  h1 { font-size: var(--text-2xl); font-weight: 700; margin-bottom: var(--space-2); }
  p { color: var(--color-text-secondary); margin-bottom: var(--space-6); }
  .error-actions { display: flex; gap: var(--space-3); justify-content: center; }
  :global(.action-btn) { padding: var(--space-3) var(--space-6); border-radius: var(--radius-md); font-size: var(--text-sm); font-weight: 600; font-family: var(--font-sans); cursor: pointer; text-decoration: none; border: none; display: inline-block; }
  :global(.action-btn-primary) { background: var(--color-primary); color: white; }
  :global(.action-btn-primary:hover) { background: var(--color-primary-hover); }
  :global(.action-btn-secondary) { background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); }
  :global(.action-btn-secondary:hover) { background: var(--color-bg); }
</style>
