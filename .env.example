# Environment variables for llmstxt-codes
# Copy to .env and fill in values

# Cloudflare D1 (configured via wrangler.toml, not env vars)
# DB binding is set in wrangler.toml

# Cloudflare R2 (configured via wrangler.toml)
# REPORTS binding is set in wrangler.toml

# Turnstile CAPTCHA (v1.1)
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Resend email API (v1.1)
# RESEND_API_KEY=

# Analytics (optional)
# PLAUSIBLE_DOMAIN=llmstxt.codes
